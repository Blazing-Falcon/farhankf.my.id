---
/** Full play-bow stretch: front paws forward, rump in the air. */
interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}

const { variant = 'light', class: className = '' } = Astro.props;
---

<svg
  class:list={['cat-stretch', className]}
  viewBox="0 0 230 132"
  aria-hidden="true"
  style={`--cat-fill: ${variant === 'dark' ? 'var(--ink)' : 'var(--paper)'}; --cat-stroke: ${variant === 'dark' ? 'var(--paper)' : 'var(--ink)'};`}
>
  <!-- tail flicked up over the raised rump -->
  <path class="cat-tail" d="M194,46 Q216,30 208,10 Q205,3 197,7" />

  <!-- body: chest low behind the head, back rising to the rump held high
       at the hips, one hind leg planted underneath -->
  <path
    class="cat-body"
    d="M64,78 Q96,52 138,42 Q176,34 192,48 Q204,60 200,74 Q196,88 186,94 L186,108 Q186,116 178,116 L170,116 Q163,116 164,108 L166,96 Q140,102 112,96 Q88,91 78,101 Z"
  />

  <!-- front legs stretched forward beneath the chin, paws staggered -->
  <path class="cat-leg" d="M64,98 L18,106 Q10,108 12,113 Q14,118 22,116 L68,108 Z" />
  <path class="cat-leg" d="M76,102 L34,114 Q26,116 28,122 Q31,126 39,123 L82,110 Z" />

  <!-- head low, chin nearly on the floor -->
  <ellipse class="cat-head" cx="50" cy="76" rx="29" ry="26" />
  <path class="cat-ear" d="M28,57 L18,25 L44,47 Z" />
  <path class="cat-ear-inner" d="M29,51 L23,34 L39,45 Z" />
  <path class="cat-ear" d="M58,49 L80,23 L74,53 Z" />
  <path class="cat-ear-inner" d="M61,45 L73,31 L68,47 Z" />

  <!-- squeezed-shut happy stretch eyes -->
  <path class="cat-eye" d="M34,76 Q40,82 46,76" />
  <path class="cat-eye" d="M54,76 Q60,82 66,76" />
  <ellipse class="cat-cheek" cx="30" cy="88" rx="7" ry="4.5" />
  <ellipse class="cat-cheek" cx="68" cy="88" rx="7" ry="4.5" />
  <path class="cat-nose" d="M46,86 L56,86 L51,92 Z" />
  <path class="cat-mouth" d="M51,92 Q51,97 45,96 M51,92 Q51,97 57,96" />

  <path class="cat-whisker" d="M24,90 Q11,88 2,92" />
  <path class="cat-whisker" d="M24,95 Q12,96 4,101" />

  <style>
    .cat-body,
    .cat-head,
    .cat-ear,
    .cat-leg {
      fill: var(--cat-fill);
      stroke: var(--cat-stroke);
      stroke-width: 3;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .cat-tail {
      fill: none;
      stroke: var(--cat-stroke);
      stroke-width: 3;
      stroke-linecap: round;
    }
    .cat-ear-inner {
      fill: var(--blush);
    }
    .cat-cheek {
      fill: var(--blush);
      opacity: 0.9;
    }
    .cat-eye,
    .cat-mouth,
    .cat-whisker {
      fill: none;
      stroke: var(--cat-stroke);
      stroke-width: 2.5;
      stroke-linecap: round;
    }
    .cat-toes {
      fill: none;
      stroke: var(--cat-stroke);
      stroke-width: 2;
      stroke-linecap: round;
    }
    .cat-nose {
      fill: var(--tangerine);
    }

    .cat-tail {
      transform-box: fill-box;
      transform-origin: bottom left;
      animation: cat-stretch-tail 3s ease-in-out infinite;
    }
    @keyframes cat-stretch-tail {
      0%,
      100% {
        transform: rotate(0deg);
      }
      50% {
        transform: rotate(6deg);
      }
    }
  </style>
</svg>
