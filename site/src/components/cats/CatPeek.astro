---
interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}

const { variant = 'light', class: className = '' } = Astro.props;
---

<svg
  class:list={['cat-peek', className]}
  viewBox="0 0 220 152"
  aria-hidden="true"
  style={`--cat-fill: ${variant === 'dark' ? 'var(--ink)' : 'var(--paper)'}; --cat-stroke: ${variant === 'dark' ? 'var(--paper)' : 'var(--ink)'};`}
>
  <!-- curly tail poking up behind, swaying -->
  <path class="cat-tail" d="M166,98 Q206,90 200,54 Q196,30 174,36 Q192,34 194,56 Q196,84 160,90" />

  <g class="cat-bob">
    <path
      class="cat-body"
      d="M52,116 C44,60 72,26 110,26 C148,26 176,60 168,116 Z"
    />

    <!-- left ear: perky -->
    <path class="cat-ear" d="M72,42 L52,6 L66,18 L56,8 L86,36 Z" />
    <path class="cat-ear-inner" d="M70,34 L60,14 L80,32 Z" />
    <!-- right ear: flopped over (a little wonky) -->
    <path class="cat-ear" d="M136,34 Q168,4 170,30 Q170,44 148,44 Z" />
    <path class="cat-ear-inner" d="M144,34 Q162,18 162,30 Q160,36 150,36 Z" />

    <!-- eyes: big and shiny, wrapped for blink -->
    <g class="cat-eyes">
      <ellipse class="cat-eye-white cat-eye-l" cx="86" cy="68" rx="13" ry="14" />
      <ellipse class="cat-eye-white cat-eye-r" cx="132" cy="68" rx="12" ry="13" />
      <circle class="cat-pupil" cx="88" cy="70" r="6.5" />
      <circle class="cat-pupil" cx="133" cy="70" r="6" />
      <circle class="cat-shine" cx="91" cy="66" r="2.6" />
      <circle class="cat-shine" cx="136" cy="66" r="2.4" />
      <circle class="cat-shine cat-shine-sm" cx="85" cy="72" r="1.4" />
      <circle class="cat-shine cat-shine-sm" cx="130" cy="72" r="1.3" />
    </g>

    <!-- rosy cheeks -->
    <ellipse class="cat-cheek" cx="68" cy="86" rx="10" ry="6" />
    <ellipse class="cat-cheek" cx="150" cy="86" rx="10" ry="6" />

    <!-- nose + smug little :3 mouth -->
    <path class="cat-nose" d="M104,82 L116,82 L110,89 Z" />
    <path class="cat-mouth" d="M110,89 Q110,96 100,95 M110,89 Q110,96 120,95" />

    <!-- blep! a cheeky tongue that peeks out on a timer -->
    <path class="cat-blep" d="M105,93 Q105,106 110,106 Q115,106 115,93 Z" />

    <path class="cat-whisker" d="M64,80 Q40,74 26,78" />
    <path class="cat-whisker" d="M64,87 Q40,88 26,94" />
    <path class="cat-whisker" d="M156,80 Q180,74 194,78" />
    <path class="cat-whisker" d="M156,87 Q180,88 194,94" />
  </g>

  <!-- grabby paws gripping the edge -->
  <g class="cat-paw-grip cat-paw-grip-l">
    <ellipse class="cat-paw" cx="74" cy="120" rx="16" ry="13" />
    <path class="cat-toes" d="M68,113 L68,120 M74,111 L74,119 M80,113 L80,120" />
  </g>
  <g class="cat-paw-grip cat-paw-grip-r">
    <ellipse class="cat-paw" cx="146" cy="120" rx="16" ry="13" />
    <path class="cat-toes" d="M140,113 L140,120 M146,111 L146,119 M152,113 L152,120" />
  </g>

  <style>
    .cat-body,
    .cat-ear,
    .cat-paw,
    .cat-tail {
      fill: var(--cat-fill);
      stroke: var(--cat-stroke);
      stroke-width: 3;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .cat-tail {
      fill: none;
    }
    .cat-ear-inner {
      fill: var(--blush);
    }
    .cat-eye-white {
      fill: var(--paper);
      stroke: var(--cat-stroke);
      stroke-width: 2.5;
    }
    .cat-pupil {
      fill: var(--ink);
    }
    .cat-shine {
      fill: var(--paper);
    }
    .cat-cheek {
      fill: var(--blush);
      opacity: 0.9;
    }
    .cat-nose {
      fill: var(--tangerine);
      stroke: var(--cat-stroke);
      stroke-width: 1.5;
      stroke-linejoin: round;
    }
    .cat-mouth,
    .cat-whisker,
    .cat-toes {
      fill: none;
      stroke: var(--cat-stroke);
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .cat-blep {
      fill: var(--blush);
      stroke: var(--cat-stroke);
      stroke-width: 2;
      transform-box: fill-box;
      transform-origin: top center;
      transform: scaleY(0);
      animation: cat-blep 9s ease-in-out infinite;
    }

    /* blink: squish the eyes shut for a beat */
    .cat-eyes {
      transform-box: fill-box;
      transform-origin: center;
      animation: cat-blink 6s ease-in-out infinite;
    }

    /* whole face does a slow curious peek-bob */
    .cat-bob {
      transform-box: fill-box;
      transform-origin: bottom center;
      animation: cat-bob 5s ease-in-out infinite;
    }

    .cat-tail {
      transform-box: fill-box;
      transform-origin: bottom left;
      animation: cat-tail-sway 3.5s ease-in-out infinite;
    }

    .cat-paw-grip-l {
      transform-box: fill-box;
      transform-origin: center;
      animation: cat-knead-l 2.6s ease-in-out infinite;
    }
    .cat-paw-grip-r {
      transform-box: fill-box;
      transform-origin: center;
      animation: cat-knead-r 2.6s ease-in-out infinite;
    }

    @keyframes cat-blink {
      0%,
      42%,
      48%,
      100% {
        transform: scaleY(1);
      }
      45% {
        transform: scaleY(0.08);
      }
    }
    @keyframes cat-blep {
      0%,
      70%,
      86%,
      100% {
        transform: scaleY(0);
      }
      76%,
      82% {
        transform: scaleY(1);
      }
    }
    @keyframes cat-bob {
      0%,
      100% {
        transform: translateY(0) rotate(0deg);
      }
      50% {
        transform: translateY(-3px) rotate(-1.2deg);
      }
    }
    @keyframes cat-tail-sway {
      0%,
      100% {
        transform: rotate(0deg);
      }
      50% {
        transform: rotate(-9deg);
      }
    }
    @keyframes cat-knead-l {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-2.5px);
      }
    }
    @keyframes cat-knead-r {
      0%,
      100% {
        transform: translateY(-2.5px);
      }
      50% {
        transform: translateY(0);
      }
    }
      </style>
</svg>
