---
/** Loafed on top of a keyboard, mid-nap, actively blocking work. */
interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}

const { variant = 'light', class: className = '' } = Astro.props;
---

<svg
  class:list={['cat-keyboard', className]}
  viewBox="0 0 220 152"
  aria-hidden="true"
  style={`--cat-fill: ${variant === 'dark' ? 'var(--ink)' : 'var(--paper)'}; --cat-stroke: ${variant === 'dark' ? 'var(--paper)' : 'var(--ink)'};`}
>
  <!-- what the cat is typing -->
  <text class="cat-typing" x="176" y="52">purrr</text>

  <!-- tail flopped across the arrow keys -->
  <path class="cat-tail" d="M168,112 Q198,106 206,86 Q210,74 200,70" />

  <!-- the loaf -->
  <path
    class="cat-body"
    d="M46,114 Q46,66 92,58 Q112,32 142,58 Q176,64 176,114 Z"
  />
  <path class="cat-ear" d="M84,50 L72,22 L96,44 Z" />
  <path class="cat-ear-inner" d="M85,44 L78,29 L93,42 Z" />
  <path class="cat-ear" d="M120,44 L142,20 L134,48 Z" />
  <path class="cat-ear-inner" d="M123,40 L137,27 L130,42 Z" />

  <!-- one eye cracked open: someone approached the desk -->
  <path class="cat-eye" d="M84,80 Q91,86 98,80" />
  <g class="cat-eye-open">
    <ellipse class="cat-eye-white" cx="121" cy="81" rx="9" ry="8" />
    <circle class="cat-pupil" cx="122" cy="82" r="4" />
    <circle class="cat-shine" cx="124" cy="79" r="1.6" />
  </g>
  <ellipse class="cat-cheek" cx="80" cy="92" rx="7" ry="4.5" />
  <ellipse class="cat-cheek" cx="132" cy="92" rx="7" ry="4.5" />
  <path class="cat-nose" d="M102,90 L110,90 L106,96 Z" />

  <path class="cat-whisker" d="M80,96 Q64,94 52,98" />
  <path class="cat-whisker" d="M132,96 Q148,94 160,98" />

  <!-- keyboard underneath -->
  <rect class="cat-kbd" x="10" y="118" width="200" height="26" rx="6" />
  <path
    class="cat-keys"
    d="M30,118 V144 M50,118 V144 M70,118 V144 M90,118 V144 M110,118 V144 M130,118 V144 M150,118 V144 M170,118 V144 M190,118 V144"
  />

  <style>
    .cat-body,
    .cat-ear {
      fill: var(--cat-fill);
      stroke: var(--cat-stroke);
      stroke-width: 3;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .cat-tail {
      fill: none;
      stroke: var(--cat-stroke);
      stroke-width: 3;
      stroke-linecap: round;
    }
    .cat-ear-inner {
      fill: var(--blush);
    }
    .cat-cheek {
      fill: var(--blush);
      opacity: 0.9;
    }
    .cat-eye,
    .cat-whisker {
      fill: none;
      stroke: var(--cat-stroke);
      stroke-width: 2.5;
      stroke-linecap: round;
    }
    .cat-eye-white {
      fill: var(--paper);
      stroke: var(--cat-stroke);
      stroke-width: 2.5;
    }
    .cat-pupil {
      fill: var(--ink);
    }
    .cat-shine {
      fill: var(--paper);
    }
    .cat-nose {
      fill: var(--tangerine);
    }
    .cat-kbd {
      fill: var(--cat-fill);
      stroke: var(--cat-stroke);
      stroke-width: 3;
    }
    .cat-keys {
      fill: none;
      stroke: var(--cat-stroke);
      stroke-width: 2;
      opacity: 0.55;
    }
    .cat-typing {
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 700;
      fill: var(--cat-stroke);
      opacity: 0;
      animation: cat-typing 8s ease-in-out infinite;
    }

    @keyframes cat-typing {
      0%,
      60%,
      95%,
      100% {
        opacity: 0;
      }
      70%,
      88% {
        opacity: 0.8;
      }
    }
      </style>
</svg>
