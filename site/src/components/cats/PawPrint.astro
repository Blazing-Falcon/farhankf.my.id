---
interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}

const { variant = 'light', class: className = '' } = Astro.props;
---

<svg
  class:list={['paw-print', className]}
  viewBox="0 0 60 60"
  aria-hidden="true"
  style={`--cat-fill: ${variant === 'dark' ? 'var(--ink)' : 'var(--paper)'}; --cat-stroke: ${variant === 'dark' ? 'var(--paper)' : 'var(--ink)'};`}
>
  <ellipse class="paw-pad" cx="30" cy="40" rx="16" ry="13" />
  <ellipse class="paw-toe" cx="12" cy="18" rx="7" ry="9" />
  <ellipse class="paw-toe" cx="27" cy="10" rx="7" ry="9" />
  <ellipse class="paw-toe" cx="42" cy="12" rx="7" ry="9" />
  <ellipse class="paw-toe" cx="52" cy="24" rx="6.5" ry="8.5" />

  <style>
    .paw-pad,
    .paw-toe {
      fill: var(--cat-fill);
      stroke: var(--cat-stroke);
      stroke-width: 3;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  </style>
</svg>
