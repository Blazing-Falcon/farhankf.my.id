---
import { Image } from 'astro:assets';
import type { Project } from '../lib/strapi';
import { mediaUrl } from '../lib/strapi';
import TechPill from './TechPill.astro';
import PawPrint from './cats/PawPrint.astro';

interface Props {
  project: Project;
  variant?: 'featured' | 'grid';
  rotate?: number;
  /** Match the page's outline: h3 under a section h2 (default), h2 under a page h1. */
  headingLevel?: 'h2' | 'h3';
}

const { project, variant = 'grid', rotate = 0, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
const cover = project.coverImage;
const coverSrc = mediaUrl(cover);
const year = project.finishedAt ? new Date(project.finishedAt).getFullYear() : null;

const difficultyLabels: Record<string, string> = {
  'weekend-hack': 'Weekend hack',
  'semester-project': 'Semester project',
  'thesis-grade': 'Thesis grade',
  'ongoing-saga': 'Ongoing saga',
};
const difficulty = project.difficulty ? difficultyLabels[project.difficulty] : null;
const stats = (project.stats ?? []).slice(0, 3);
const pills = (project.techStack ?? []).slice(0, 5);
const extraPills = (project.techStack?.length ?? 0) - pills.length;
---

<article
  class:list={['project-card', variant]}
  style={`--rotate: ${rotate}deg;`}
  data-reveal
>
  <div class="project-card-cover">
    <span class="tape" aria-hidden="true"></span>
    {
      coverSrc && cover?.width && cover?.height ? (
        <Image
          src={coverSrc}
          width={cover.width}
          height={cover.height}
          alt={cover.alternativeText ?? project.title}
        />
      ) : (
        <svg class="cover-doodle" viewBox="0 0 320 200" aria-hidden="true">
          <path class="doodle-axis" d="M36,20 L36,168 L296,168" />
          <path class="doodle-line" d="M36,150 Q100,120 150,96 T296,40" />
          <circle class="doodle-dot" cx="70" cy="140" r="5" />
          <circle class="doodle-dot" cx="120" cy="118" r="5" />
          <circle class="doodle-dot" cx="170" cy="88" r="5" />
          <circle class="doodle-dot" cx="220" cy="76" r="5" />
          <circle class="doodle-dot doodle-dot-outlier" cx="250" cy="130" r="5" />
          <text class="doodle-note" x="240" y="152">outlier (cat)</text>
        </svg>
      )
    }
    {year && <span class="year-stamp">{year}</span>}
    <div class="hover-paw" aria-hidden="true">
      <PawPrint />
    </div>
  </div>

  <div class="project-card-body">
    {difficulty && <span class="difficulty-sticker">{difficulty}</span>}
    <Heading class="project-card-title">
      <a href={`/projects/${project.slug}`} class="project-card-link">
        {project.title}
      </a>
    </Heading>
    <p class="project-card-summary">{project.summary}</p>

    {
      stats.length > 0 && (
        <dl class="project-card-stats">
          {stats.map((stat) => (
            <div class="stat">
              <dd>{stat.value}</dd>
              <dt>{stat.label}</dt>
            </div>
          ))}
        </dl>
      )
    }

    {
      pills.length > 0 && (
        <div class="project-card-pills">
          {pills.map((tech) => (
            <TechPill label={tech} />
          ))}
          {extraPills > 0 && <TechPill label={`+${extraPills}`} />}
        </div>
      )
    }

    {
      (project.projectUrl || project.repoUrl) && (
        <div class="project-card-links">
          {project.projectUrl && (
            <a href={project.projectUrl} target="_blank" rel="noreferrer">
              Live ↗
            </a>
          )}
          {project.repoUrl && (
            <a href={project.repoUrl} target="_blank" rel="noreferrer">
              Code ↗
            </a>
          )}
        </div>
      )
    }
  </div>
</article>

<style>
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border: var(--border-thick);
    border-radius: var(--radius-card);
    color: var(--ink);
    transform: rotate(var(--rotate));
    box-shadow: var(--shadow-hard);
    transition:
      transform 0.25s ease-out,
      box-shadow 0.25s ease-out;
  }

  .project-card:hover,
  .project-card:focus-within {
    transform: rotate(calc(var(--rotate) * -0.5)) translate(-2px, -4px);
    box-shadow: 8px 10px 0 var(--ink);
  }

  /* The whole card is clickable via the title's stretched link; real links
     inside sit above it. */
  .project-card-link {
    color: inherit;
    text-decoration: none;
  }

  .project-card-link::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
  }

  .project-card-cover {
    position: relative;
    border-bottom: var(--border-thick);
    border-radius: 10px 10px 0 0;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--blush);
  }

  .project-card-cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tape {
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    width: 92px;
    height: 22px;
    background: var(--butter);
    border: 2px solid var(--ink);
    opacity: 0.9;
    z-index: 2;
  }

  .cover-doodle {
    width: 100%;
    height: 100%;
    display: block;
  }

  .doodle-axis {
    fill: none;
    stroke: var(--ink);
    stroke-width: 3;
    stroke-linecap: round;
  }

  .doodle-line {
    fill: none;
    stroke: var(--teal);
    stroke-width: 3;
    stroke-dasharray: 7 7;
    stroke-linecap: round;
  }

  .doodle-dot {
    fill: var(--tangerine);
    stroke: var(--ink);
    stroke-width: 2;
  }

  .doodle-dot-outlier {
    fill: var(--butter);
  }

  .doodle-note {
    font-family: var(--font-mono);
    font-size: 12px;
    fill: var(--ink);
    text-anchor: middle;
  }

  .year-stamp {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-tiny);
    letter-spacing: 0.08em;
    background: var(--paper);
    border: 2px solid var(--ink);
    border-radius: var(--radius-pill);
    padding: 2px var(--space-3);
    transform: rotate(3deg);
    z-index: 2;
  }

  .hover-paw {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    width: 34px;
    opacity: 0;
    transform: rotate(-12deg) scale(0.7);
    transition:
      opacity 0.25s ease-out,
      transform 0.25s ease-out;
    pointer-events: none;
  }

  .project-card:hover .hover-paw {
    opacity: 0.9;
    transform: rotate(-12deg) scale(1);
  }

  .project-card-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-5);
  }

  .difficulty-sticker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--butter);
    border: 2px solid var(--ink);
    border-radius: var(--radius-pill);
    padding: 2px var(--space-3);
    transform: rotate(-2deg);
  }

  .project-card-title {
    font-size: var(--text-sub);
    line-height: 1.1;
  }

  .project-card-summary {
    margin: 0;
    color: var(--ink);
    font-size: var(--text-small);
  }

  .project-card-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
    margin: 0;
    padding: var(--space-2) var(--space-3);
    border: 2px dashed var(--teal);
    border-radius: var(--radius-card);
  }

  .stat {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .stat dd {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
    color: var(--teal);
  }

  .stat dt {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-card-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .project-card-links {
    display: flex;
    gap: var(--space-4);
    position: relative;
    z-index: 1;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-tiny);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (min-width: 768px) {
    .project-card.featured {
      flex-direction: row;
    }

    .project-card.featured .project-card-cover {
      width: 45%;
      aspect-ratio: auto;
      border-bottom: none;
      border-right: var(--border-thick);
      border-radius: 10px 0 0 10px;
    }

    .project-card.featured .project-card-body {
      width: 55%;
      justify-content: center;
    }

    .project-card.featured .project-card-title {
      font-size: 1.75rem;
    }

    .project-card.featured .project-card-summary {
      font-size: var(--text-body);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .hover-paw {
      transition: none;
    }
  }
</style>
