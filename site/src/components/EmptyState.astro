---
import CatLoaf from './cats/CatLoaf.astro';

interface Props {
  message?: string;
  class?: string;
}

const { message = 'This content took a nap. Try again in a moment.', class: className = '' } =
  Astro.props;
---

<div class:list={['empty-state', className]}>
  <div class="empty-state-cat">
    <CatLoaf />
  </div>
  <p class="empty-state-message">{message}</p>
</div>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    padding: var(--space-8) var(--space-4);
  }

  .empty-state-cat {
    width: 180px;
  }

  .empty-state-message {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.9rem;
    color: var(--ink);
    max-width: 32ch;
    margin: 0;
  }
</style>
