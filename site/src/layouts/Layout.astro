---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CatPeek from '../components/cats/CatPeek.astro';
import CatWalk from '../components/cats/CatWalk.astro';
import PawPrint from '../components/cats/PawPrint.astro';

interface Props {
  title: string;
  description?: string;
  /** Absolute or root-relative image for the link preview. Defaults to /og.png. */
  image?: string;
}

const {
  title,
  description = 'ComSci, Statistics, machine learning, photography, and a home lab.',
  image,
} = Astro.props;

const fullTitle = `${title} · farhankf.cat`;
// Crawlers reject relative og:image/og:url — resolve against the configured site.
const base = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, base).href;
const ogImage = new URL(image ?? '/og.png', base).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <title>{fullTitle}</title>

    {/* Link previews: WhatsApp, Discord, Slack, Telegram all read these. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="farhankf.cat" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {
      /* Dimensions are only known for the default card — a page-supplied image
         has its own, and lying about them makes previews render blank. */
      !image && (
        <Fragment>
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
        </Fragment>
      )
    }
    <meta property="og:image:alt" content="farhankf.cat — machine learning, photography, and a home lab" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {/* Colors the accent stripe on Discord embeds. */}
    <meta name="theme-color" content="#ff5c00" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Inert cat stock for the easter-egg script to clone from. -->
    <template id="egg-tpl-peek"><CatPeek /></template>
    <template id="egg-tpl-walk"><CatWalk /></template>
    <template id="egg-tpl-paw"><PawPrint /></template>

    <script src="../scripts/motion.ts"></script>
    <script src="../scripts/easter-eggs.ts"></script>
  </body>
</html>
