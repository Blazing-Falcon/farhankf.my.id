---
import { getImage, Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import StickerBadge from '../components/StickerBadge.astro';
import EmptyState from '../components/EmptyState.astro';
import CatStretch from '../components/cats/CatStretch.astro';
import Lightbox from '../components/Lightbox.tsx';
import { getPhotos, mediaUrl, type Photo, type PhotoCategory } from '../lib/strapi';

const categories: PhotoCategory[] = ['street', 'landscape', 'portrait', 'macro', 'other'];
const activeCategory = Astro.url.searchParams.get('category') as PhotoCategory | null;

let photos: Photo[] = [];
let hadError = false;

try {
  photos = await getPhotos(
    activeCategory && categories.includes(activeCategory) ? { category: activeCategory } : {}
  );
} catch {
  hadError = true;
}

const lightboxPhotos = await Promise.all(
  photos.map(async (photo) => {
    const src = mediaUrl(photo.image);
    if (!src || !photo.image?.width || !photo.image?.height) {
      return { src: '', width: 800, height: 600, alt: photo.title, title: photo.title, caption: photo.title, gear: photo.gear ?? '' };
    }
    const optimized = await getImage({
      src,
      width: photo.image.width,
      height: photo.image.height,
      format: 'webp',
    });
    return {
      src: optimized.src,
      width: photo.image.width,
      height: photo.image.height,
      alt: photo.image.alternativeText ?? photo.title,
      title: photo.title,
      caption: photo.caption ?? photo.title,
      gear: photo.gear ?? '',
    };
  })
);

const shotDate = (photo: Photo) =>
  photo.shotAt
    ? new Date(photo.shotAt).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })
    : null;
---

<Layout title="Photography" description="Photography through the lens.">
  <section class="section-inner photography-page">
    <div class="page-head">
      <div>
        <StickerBadge label="Through the lens" rotate={2} />
        <h1 data-reveal>Photography</h1>
        <p class="page-sub">
          Field notes in light. Every frame develops straight into the lab notebook — gear and
          coordinates stamped below.
        </p>
      </div>
      <div class="page-head-cat" aria-hidden="true">
        <CatStretch />
      </div>
    </div>

    <nav class="category-filters" aria-label="Filter by category">
      <a href="/photography" class:list={['category-pill', { active: !activeCategory }]}>All</a>
      {
        categories.map((category) => (
          <a
            href={`/photography?category=${category}`}
            class:list={['category-pill', { active: activeCategory === category }]}
          >
            {category}
          </a>
        ))
      }
    </nav>

    {
      hadError ? (
        <EmptyState message="Photos are napping. Check back once Strapi wakes up." />
      ) : photos.length === 0 ? (
        <EmptyState message="No photos in this category yet." />
      ) : (
        <div class="masonry-grid">
          {photos.map((photo, i) => (
            <button
              type="button"
              class="polaroid"
              style={`--tilt: ${[-1.5, 1, -0.5, 1.5][i % 4]}deg;`}
              data-photo-index={i}
              aria-label={`Open ${photo.title}`}
            >
              <span class="polaroid-tape" aria-hidden="true" />
              {photo.image?.width && photo.image?.height && (
                <Image
                  src={mediaUrl(photo.image)}
                  width={photo.image.width}
                  height={photo.image.height}
                  widths={[360, 720]}
                  sizes="(min-width: 1024px) 350px, (min-width: 640px) 46vw, 92vw"
                  alt={photo.image.alternativeText ?? photo.title}
                />
              )}
              <span class="polaroid-meta">
                <span class="polaroid-title">{photo.title}</span>
                <span class="polaroid-exif">
                  {photo.gear && <span>{photo.gear}</span>}
                  {shotDate(photo) && <span>{shotDate(photo)}</span>}
                </span>
                <span class="polaroid-stamp">{photo.category}</span>
              </span>
            </button>
          ))}
        </div>
      )
    }
  </section>

  <Lightbox photos={lightboxPhotos} client:visible />
</Layout>

<style>
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-5);
  }

  .photography-page {
    padding-top: var(--space-7);
    padding-bottom: var(--section-gap);
  }

  .page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .page-head h1 {
    font-size: var(--text-section);
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .page-sub {
    font-size: var(--text-body);
    max-width: 52ch;
    margin: 0 0 var(--space-5);
  }

  .page-head-cat {
    width: 190px;
    flex-shrink: 0;
    margin-bottom: var(--space-2);
  }

  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-7);
  }

  .category-pill {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--text-tiny);
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border: var(--border-thick);
    border-radius: var(--radius-pill);
    background: var(--paper);
    transition:
      transform 0.2s ease-out,
      background-color 0.2s ease-out;
  }

  .category-pill:hover {
    transform: translateY(-2px);
  }

  .category-pill.active {
    background: var(--teal);
    color: var(--paper);
  }

  .masonry-grid {
    columns: 1;
    column-gap: var(--space-6);
  }

  .polaroid {
    position: relative;
    display: block;
    width: 100%;
    margin-bottom: var(--space-6);
    break-inside: avoid;
    background: var(--paper);
    border: var(--border-thick);
    box-shadow: var(--shadow-hard);
    padding: var(--space-3) var(--space-3) var(--space-4);
    cursor: pointer;
    text-align: left;
    transform: rotate(var(--tilt, 0deg));
    transition:
      transform 0.25s ease-out,
      box-shadow 0.25s ease-out;
  }

  .polaroid:hover,
  .polaroid:focus-visible {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: 8px 10px 0 var(--ink);
    z-index: 1;
  }

  .polaroid-tape {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    width: 76px;
    height: 20px;
    background: var(--butter);
    border: 2px solid var(--ink);
    opacity: 0.9;
    z-index: 1;
  }

  .polaroid :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border: 2px solid var(--ink);
  }

  .polaroid-meta {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-top: var(--space-3);
  }

  .polaroid-title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-tiny);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink);
  }

  .polaroid-exif {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink);
    opacity: 0.75;
  }

  .polaroid-stamp {
    position: absolute;
    right: 0;
    top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--teal);
    border: 2px solid var(--teal);
    border-radius: 4px;
    padding: 1px var(--space-2);
    transform: rotate(-6deg);
    opacity: 0.85;
  }

  @media (min-width: 640px) {
    .masonry-grid {
      columns: 2;
    }
  }

  @media (min-width: 1024px) {
    .masonry-grid {
      columns: 3;
    }
  }

  @media (max-width: 767px) {
    .page-head-cat {
      display: none;
    }
  }
</style>
