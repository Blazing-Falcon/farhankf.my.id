---
import Layout from '../layouts/Layout.astro';
import Ticker from '../components/Ticker.astro';
import StickerBadge from '../components/StickerBadge.astro';
import ProjectCard from '../components/ProjectCard.astro';
import EmptyState from '../components/EmptyState.astro';
import CatPeek from '../components/cats/CatPeek.astro';
import CatCamera from '../components/cats/CatCamera.astro';
import CatSleep from '../components/cats/CatSleep.astro';
import CatKeyboard from '../components/cats/CatKeyboard.astro';
import CatTail from '../components/cats/CatTail.astro';
import PawPrint from '../components/cats/PawPrint.astro';
import ResearcherProfile from '../components/ResearcherProfile.astro';
import { profileFacts } from '../lib/profileFacts';
import { Image } from 'astro:assets';
import {
  getProjects,
  getPhotos,
  getLabNotes,
  getTicker,
  mediaUrl,
  type Project,
  type Photo,
  type About,
  type LabNote,
} from '../lib/strapi';

let about: About | null = null;
let featuredProjects: Project[] = [];
let featuredPhotos: Photo[] = [];
let labNotes: LabNote[] = [];
let hadError = false;

try {
  [about, featuredProjects, featuredPhotos, labNotes] = await Promise.all([
    Astro.locals.about(),
    getProjects({ featuredOnly: true }),
    getPhotos({ featuredOnly: true }),
    getLabNotes(),
  ]);
} catch {
  hadError = true;
}

featuredProjects = featuredProjects.slice(0, 3);

// Ticker content is decorative; fall back to the defaults rather than letting
// a missing/unpublished Ticker entry (404) drag the rest of the page down.
const defaultTopics = [
  'STATISTICS',
  'MACHINE LEARNING',
  'PHOTOGRAPHY',
  'HOME LAB',
  'LINUX',
  'OPEN SOURCE',
  'CATS',
  'COFFEE',
  'D&D',
  'DATA VIZ',
  'R',
  'PYTHON',
  'SQL',
];
let tickerTopics = defaultTopics;
try {
  const ticker = await getTicker();
  if (ticker?.topics?.length) tickerTopics = ticker.topics;
} catch {
  // keep defaults
}

// Presentation only — content comes from the CMS.
const noteTilts = [-2, 1.5, -1, 2];

// The teaser shows the four funniest rows; the About page shows all six.
const teaserFactLabels = ['Field', 'Based in', 'Current obsession', 'Supervisors'];
const teaserFacts = profileFacts(about).filter((f) => teaserFactLabels.includes(f.label));
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow">
        <span class="hero-eyebrow-dot"></span>Stats · ML · Photography · Home lab
      </p>
      <h1 class="hero-headline">
        <span class="hero-line-mask"><span class="hero-line" data-hero-line>DATA, PIXELS,</span></span>
        <span class="hero-line-mask"
          ><span class="hero-line" data-hero-line>&amp; ONE SHY <mark class="hero-highlight">CAT</mark>.</span
          ></span
        >
      </h1>
      <p class="hero-descriptor">
        A statistics student's lab notebook that a very confident cat has walked across.
        Mind the paw prints.
      </p>
      <div class="hero-actions">
        <a href="/projects" class="btn btn-primary press-shadow">See projects</a>
        <a href="/about" class="btn btn-secondary press-shadow">About me</a>
      </div>
    </div>

    <div class="lab-bench" aria-hidden="true">
      <div class="bench-cat" data-hero-mascot>
        <CatPeek />
      </div>
      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-title">train.log</span>
        </div>
        <pre class="terminal-body">juan@lab:~$ python train.py --data life.csv
loading 9 lives .......... ok
fitting StudentLifeClassifier
[████████░░] epoch 8/10
accuracy: 0.94   loss: naps
warn: cat on keyboard, resuming…
juan@lab:~$ <span class="terminal-cursor">▌</span></pre>
      </div>
      <div class="sticky-note">
        <strong>TODO</strong>
        feed the cats <em>before</em> deploying
      </div>
      <div class="bench-paw bench-paw-1"><PawPrint /></div>
      <div class="bench-paw bench-paw-2"><PawPrint /></div>
    </div>
  </section>

  <Ticker items={tickerTopics} />

  <section class="section featured-section">
    <div class="section-inner">
      <div class="section-head">
        <div>
          <StickerBadge label="Fresh from the lab" rotate={-3} />
          <h2 class="section-title" data-reveal>Featured projects</h2>
          <p class="section-sub">
            The experiments that made it past peer review (the cats). Full write-ups, data
            and regrets included.
          </p>
        </div>
        <div class="section-head-cat" aria-hidden="true">
          <CatSleep />
        </div>
      </div>
      {
        hadError || featuredProjects.length === 0 ? (
          <EmptyState message="Projects are napping. Check back once Strapi wakes up." />
        ) : (
          <div class="featured-projects">
            {featuredProjects.map((project, i) => (
              <ProjectCard project={project} variant="grid" compact rotate={i % 2 === 0 ? -1 : 1} />
            ))}
          </div>
        )
      }
      <div class="section-more">
        <a href="/projects" class="btn btn-secondary press-shadow">All projects</a>
      </div>
    </div>
  </section>

  <section class="photography-strip">
    <div class="section-inner">
      <StickerBadge label="Through the lens" rotate={2} />
      <h2 class="section-title" data-reveal>Photography</h2>
      <p class="section-sub">
        Off-hours evidence collection. Fuji in hand, cats judging the compositions.
      </p>
      {
        hadError || featuredPhotos.length === 0 ? (
          <EmptyState message="Photos are napping. Check back once Strapi wakes up." />
        ) : (
          <div class="photo-row">
            <div class="photo-row-mascot">
              <CatCamera variant="dark" />
            </div>
            {featuredPhotos.slice(0, 8).map((photo, i) => (
              <figure class="polaroid" style={`--tilt: ${i % 2 === 0 ? -1.5 : 1.5}deg;`}>
                <span class="polaroid-tape" aria-hidden="true" />
                {photo.image?.url && photo.image.width && photo.image.height ? (
                  <Image
                    src={mediaUrl(photo.image)}
                    width={photo.image.width}
                    height={photo.image.height}
                    widths={[220, 440]}
                    sizes="220px"
                    alt={photo.image.alternativeText ?? photo.title}
                  />
                ) : null}
                <figcaption>{photo.title}</figcaption>
              </figure>
            ))}
          </div>
        )
      }
      <div class="section-more">
        <a href="/photography" class="btn btn-dark press-shadow">Full gallery</a>
      </div>
    </div>
  </section>

  <section class="section labnotes-section">
    <div class="section-inner">
      <div class="section-head">
        <div>
          <StickerBadge label="Pinned to the board" rotate={-2} />
          <h2 class="section-title" data-reveal>Lab notes</h2>
          <p class="section-sub">Current state of the laboratory, updated whenever the supervisors allow it.</p>
        </div>
        <div class="section-head-cat labnotes-cat" aria-hidden="true">
          <CatKeyboard />
        </div>
      </div>
      {
        hadError || labNotes.length === 0 ? (
          <EmptyState message="The board is empty. Pin some lab notes in Strapi." />
        ) : (
          <div class="labnotes-grid">
            {labNotes.map((note, i) => (
              <div class="labnote" style={`--tilt: ${noteTilts[i % noteTilts.length]}deg;`} data-reveal>
                <span class="labnote-pin" aria-hidden="true" />
                <h3>{note.title}</h3>
                <p>{note.body}</p>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <section class="section about-teaser">
    <div class="section-inner">
      <div class="about-teaser-wrap">
        <div class="teaser-tail" aria-hidden="true">
          <CatTail />
        </div>
        <div class="about-teaser-panel">
          {
            about?.portrait && (
              <div class="about-teaser-portrait">
                <Image
                  src={mediaUrl(about.portrait)}
                  width={about.portrait.width ?? 400}
                  height={about.portrait.height ?? 400}
                  widths={[220, 440]}
                  sizes="220px"
                  alt={about.portrait.alternativeText ?? 'Portrait'}
                />
              </div>
            )
          }
          <div class="about-teaser-copy" data-reveal>
            <StickerBadge label="Who is this cat" rotate={-2} />
            <h2 class="section-title">One student, six cats, and an ISP that fights back.</h2>
            <a href="/about" class="btn btn-secondary press-shadow">Read the full story</a>
          </div>
          <div class="about-teaser-profile">
            <ResearcherProfile facts={teaserFacts} headingLevel="h3" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="decor-paw" data-parallax aria-hidden="true">
    <PawPrint />
  </div>
</Layout>

<style>
  /* ——— Hero: two columns, ~25% shorter than the old full-viewport version */
  .hero {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-7);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--text-tiny);
    font-weight: 700;
    color: var(--teal);
    margin: 0 0 var(--space-4);
  }

  .hero-eyebrow-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--tangerine);
    border: 2px solid var(--ink);
  }

  .hero-headline {
    font-size: var(--text-hero);
    display: flex;
    flex-direction: column;
  }

  .hero-line-mask {
    display: block;
    overflow: hidden;
    padding: 0.06em 0;
  }

  .hero-line {
    display: block;
  }

  .hero-highlight {
    background: var(--butter);
    color: var(--ink);
    padding: 0 0.12em;
    box-decoration-break: clone;
    box-shadow: 3px 3px 0 var(--ink);
  }

  .hero-descriptor {
    font-size: 1.25rem;
    max-width: 44ch;
    margin-top: var(--space-5);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-6);
    flex-wrap: wrap;
  }

  /* ——— The lab bench: terminal + sticky note + supervising cat */
  .lab-bench {
    position: relative;
    justify-self: center;
    width: min(100%, 420px);
    padding-top: 84px; /* room for the cat hooked over the terminal */
  }

  .bench-cat {
    position: absolute;
    top: 0;
    left: 50%;
    /* `translate`, not `transform`: composes with motion.ts's `scale` pop-in
       keyframes without the -50% offset getting scaled along (off-center cat) */
    translate: -50%;
    width: 150px;
    z-index: 2;
  }

  .terminal {
    position: relative;
    background: var(--ink);
    border: var(--border-thick);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-hard);
    transform: rotate(-1deg);
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-bottom: 2px solid var(--paper);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--paper);
    opacity: 0.5;
  }

  .terminal-dot:first-child {
    background: var(--tangerine);
    opacity: 1;
  }

  .terminal-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--paper);
    opacity: 0.7;
  }

  .terminal-body {
    margin: 0;
    padding: var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.7;
    color: var(--paper);
    white-space: pre-wrap;
  }

  .terminal-cursor {
    animation: cursor-blink 1.1s steps(1) infinite;
  }

  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }

  .sticky-note {
    position: absolute;
    right: -14px;
    bottom: -26px;
    width: 170px;
    background: var(--butter);
    border: var(--border-thick);
    box-shadow: 4px 4px 0 var(--ink);
    transform: rotate(3deg);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.5;
    z-index: 3;
  }

  .sticky-note strong {
    display: block;
    letter-spacing: 0.1em;
  }

  .bench-paw {
    position: absolute;
    width: 30px;
    opacity: 0.25;
  }

  .bench-paw-1 {
    left: -34px;
    bottom: 30px;
    transform: rotate(-20deg);
  }

  .bench-paw-2 {
    left: -58px;
    bottom: -8px;
    transform: rotate(12deg);
  }

  /* ——— Shared section scaffolding (buttons live in global.css) */
  .section {
    padding: var(--section-gap) 0;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-5);
  }

  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .section-head-cat {
    width: 130px;
    flex-shrink: 0;
    margin-bottom: -6px;
  }

  .section-title {
    font-size: var(--text-section);
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .section-sub {
    font-size: var(--text-body);
    max-width: 52ch;
    margin: 0;
  }

  .section-more {
    margin-top: var(--space-6);
    display: flex;
    justify-content: flex-start;
  }

  /* ——— Featured projects: solid cream band so the cards pop */
  .featured-section {
    background: var(--paper);
  }

  /* same breakpoints as .projects-grid on /projects */
  .featured-projects {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .featured-projects {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .featured-projects {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ——— Photography: the dark room */
  .photography-strip {
    background: var(--ink);
    color: var(--paper);
    padding: var(--section-gap) 0;
    border-top: var(--border-thick);
    border-bottom: var(--border-thick);
  }

  .photography-strip .section-title {
    color: var(--paper);
  }

  .photography-strip .section-sub {
    color: var(--blush);
    margin-bottom: var(--space-6);
  }

  .photo-row {
    display: flex;
    gap: var(--space-5);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: var(--space-4) var(--space-2) var(--space-4);
  }

  .photo-row-mascot {
    flex-shrink: 0;
    width: 120px;
    align-self: flex-end;
  }

  .polaroid {
    position: relative;
    flex-shrink: 0;
    scroll-snap-align: start;
    background: var(--paper);
    padding: var(--space-2) var(--space-2) var(--space-4);
    border: var(--border-thick);
    box-shadow: 6px 6px 0 rgba(251, 247, 239, 0.25);
    width: 220px;
    margin: 0;
    transform: rotate(var(--tilt, -1.5deg));
    transition: transform 0.25s ease-out;
  }

  .polaroid:hover {
    transform: rotate(0deg) translateY(-4px);
  }

  .polaroid-tape {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    width: 70px;
    height: 18px;
    background: var(--butter);
    border: 2px solid var(--ink);
    opacity: 0.9;
  }

  .polaroid :global(img) {
    width: 100%;
    height: 220px;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .polaroid figcaption {
    font-family: var(--font-mono);
    color: var(--ink);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: var(--space-2);
    text-align: center;
  }

  /* ——— Lab notes: sticky notes pinned over the notebook grid */
  .labnotes-cat {
    width: 150px;
  }

  .labnotes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: var(--space-5);
  }

  .labnote {
    position: relative;
    background: var(--butter);
    border: var(--border-thick);
    box-shadow: 4px 4px 0 var(--ink);
    padding: var(--space-5) var(--space-4) var(--space-4);
    transform: rotate(var(--tilt, 0deg));
    transition: transform 0.25s ease-out;
  }

  .labnote:hover {
    transform: rotate(0deg) translateY(-3px);
  }

  .labnote:nth-child(even) {
    background: var(--blush);
  }

  .labnote-pin {
    position: absolute;
    top: -9px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: var(--tangerine);
    border: 2px solid var(--ink);
  }

  .labnote h3 {
    font-family: var(--font-mono);
    font-size: var(--text-tiny);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-2);
  }

  .labnote p {
    margin: 0;
    font-size: var(--text-small);
  }

  /* ——— About teaser with a tail poking out from behind the panel */
  .about-teaser-wrap {
    position: relative;
  }

  .teaser-tail {
    position: absolute;
    top: -58px;
    right: 60px;
    width: 44px;
    z-index: 0;
  }

  .about-teaser-panel {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: var(--space-7);
    flex-wrap: wrap;
    background: var(--butter);
    border: var(--border-thick);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-hard);
    padding: var(--space-7);
  }

  .about-teaser-portrait {
    width: 220px;
    flex-shrink: 0;
    border: var(--border-thick);
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-hard);
    background: var(--paper);
  }

  .about-teaser-portrait :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .about-teaser-copy {
    flex: 1;
    min-width: 260px;
  }

  .about-teaser-copy .section-title {
    margin-bottom: var(--space-5);
  }

  .about-teaser-profile {
    flex: 1;
    min-width: 280px;
    max-width: 420px;
  }

  .decor-paw {
    position: fixed;
    bottom: 5%;
    right: 3%;
    width: 60px;
    opacity: 0.15;
    pointer-events: none;
    z-index: -1;
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 1.15fr 0.85fr;
      padding-top: var(--space-8);
    }
  }

  @media (max-width: 899px) {
    .lab-bench {
      width: min(100%, 380px);
    }

    .section-head-cat {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .about-teaser-panel {
      padding: var(--space-5);
    }

    .sticky-note {
      right: 0;
    }
  }
</style>
