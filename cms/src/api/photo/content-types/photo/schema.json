{
  "kind": "collectionType",
  "collectionName": "photos",
  "info": {
    "singularName": "photo",
    "pluralName": "photos",
    "displayName": "Photo"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "caption": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "default": "other",
      "enum": [
        "street",
        "landscape",
        "astro",
        "portrait",
        "macro",
        "other"
      ]
    },
    "shotAt": {
      "type": "date"
    },
    "gear": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
    }
  }
}
